# Force LF line endings in the repo for text files.
# Avoids CRLF noise when committing from Windows.
* text=auto eol=lf

*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf

# Treat common binary types correctly
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
